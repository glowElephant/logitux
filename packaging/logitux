#!/bin/sh
# logitux 실행 래퍼 — /usr/share/logitux/main.py 를 실행한다.
# PySide6(GUI)가 없으면 친절히 안내하고 종료한다.
if ! python3 -c "import PySide6" 2>/dev/null; then
    msg="logitux: GUI 라이브러리(PySide6)가 설치되지 않았습니다.\n터미널에서 'pip3 install pyside6' 를 실행한 뒤 다시 시도하세요."
    printf "%b\n" "$msg" >&2
    if command -v zenity >/dev/null 2>&1; then
        zenity --error --no-wrap --text="$msg" 2>/dev/null || true
    fi
    exit 1
fi
exec python3 /usr/share/logitux/main.py "$@"
